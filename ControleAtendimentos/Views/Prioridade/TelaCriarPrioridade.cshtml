@model ControleAtendimentos.DTOs.PrioridadeDTO.PrioridadeDTORequest

@{
    ViewData["Title"] = "Cadastrar Prioridade";
}

<div class="text-center mb-4">
    <h1 class="display-4">Cadastrar Prioridade</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-controller="Prioridade" asp-action="Criar" method="post">

                    <div class="mb-3">
                        <label asp-for="nome" class="form-label">Nome da Prioridade</label>
                        <input asp-for="nome" class="form-control" placeholder="Ex: Alta, Média, Baixa..." />
                        <span asp-validation-for="nome" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="tempoEstimado" class="form-label">Tempo Estimado (hh:mm:ss)</label>
                        <input asp-for="tempoEstimado" class="form-control" placeholder="Ex: 01:30:00" />
                        <span asp-validation-for="tempoEstimado" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Cadastrar</button>
                        <a asp-controller="Prioridade" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
