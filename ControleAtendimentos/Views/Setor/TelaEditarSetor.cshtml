@model ControleAtendimentos.DTOs.SetorDTO.SetorDTOResponse


@{
    ViewData["Title"] = "Editar Setor";
}

<div class="text-center">
    <h1 class="display-4">Editar Setor</h1>
    <br />
</div>
<div>
    <form asp-controller="Setor" asp-action="Editar" method="post">

        <input type="hidden" asp-for="id"/>

        <div class="mb-3">
            <label asp-for="nome" class="form-label">Nome do Setor</label>
            <input asp-for="nome" class="form-control" placeholder="Ex: Suporte, TI, RH..." />
            <span asp-validation-for="nome" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Salvar</button>
            <a asp-controller="Setor" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>
